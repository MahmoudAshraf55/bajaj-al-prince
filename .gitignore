# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit real secrets
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
# ALLOW .env.example to be committed as a template
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database
*.db
*.db-journal
*.db-wal
*.db-shm
/prisma/migrations/migration_lock.toml

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
Thumbs.db

# test results
test-results/
playwright-report/
blob-report/
all-blob-reports/

# logs
logs/
*.log

# local scratch / backup files
*.bak
*-test.html
/zod/

# local AI/tooling state
.blackboxcli/

# git worktree directories created inside this checkout
worktree-*/

# runtime session credentials
.baileys_auth/
services/whatsapp/.baileys_auth/
