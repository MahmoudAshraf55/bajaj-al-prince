# =============================================================================
# BAJAJ AL PRINCE — Environment Configuration Template
# =============================================================================
# 1. Copy this file → .env  (or run: npm run setup)
# 2. Fill in REAL values — NEVER commit .env to git
# 3. Keep this file in sync with Vercel Environment Variables
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED — app will crash or refuse auth without these
# ---------------------------------------------------------------------------

# PostgreSQL connection string (local or Neon/Supabase/RDS)
DATABASE_URL="postgresql://user:password@localhost:5432/bajaj_al_prince?schema=public"

# HS256 secret for JWT signing. Min 32 bytes hex.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-cryptographically-secure-secret-min-64-chars"

# Initial admin password for `prisma db seed`
ADMIN_INITIAL_PASSWORD="replace-with-strong-password"

# Public URL (used for sitemap, CORS, security headers)
# Local: http://localhost:3000
# Prod: https://bajajalprince.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# WhatsApp number for chatbot + market inquiries (WITHOUT + sign)
WHATSAPP_NUMBER="201015544084"
NEXT_PUBLIC_WHATSAPP_NUMBER="201015544084"

# ---------------------------------------------------------------------------
# OPTIONAL — features degrade gracefully when missing
# ---------------------------------------------------------------------------

# Separate secret for refresh tokens (falls back to JWT_SECRET)
# JWT_REFRESH_SECRET="replace-with-another-secure-secret"

# URL of the standalone WhatsApp microservice
WHATSAPP_SERVICE_URL="http://localhost:3001"

# Upstash Redis for production rate limiting (falls back to in-memory)
# UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# AI Image Generation (Pollinations API)
# POLLINATIONS_API_KEY="sk-your-key"

# SMTP — for booking confirmations and contact form notifications
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your@email.com"
# SMTP_PASS="app-password"
# FROM_EMAIL="noreply@bajajalprince.com"

# TikTok username for embedded player (without @)
# NEXT_PUBLIC_TIKTOK_USERNAME="elprince.bajajj"
# NEXT_PUBLIC_TIKTOK_FORCE_LIVE=""

# Analytics
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# ---------------------------------------------------------------------------
# SECURITY
# ---------------------------------------------------------------------------
# 1. NEVER commit .env to version control
# 2. Rotate secrets quarterly
# 3. Use different secrets per environment (dev / staging / prod)
# 4. Keep Vercel env vars in sync with this file
# =============================================================================
