# =============================================================================
# BAJAJ AL PRINCE — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in REAL values.
# NEVER commit .env to version control.
# Regenerate JWT_SECRET using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# =============================================================================

# ---------------------------------------------------------------------------
# Database (PostgreSQL required)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/bajaj_al_prince?schema=public"

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# HS256 secret for JWT signing. Must be at least 32 bytes.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-cryptographically-secure-secret-min-64-chars"

# Initial admin password for Prisma seed. Must be set before running seed.
ADMIN_INITIAL_PASSWORD="replace-with-strong-password"

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Optional: Analytics / Monitoring
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_GA_ID=""
# SENTRY_DSN=""
Redis (Upstash) — Required for rate limiting
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ---------------------------------------------------------------------------
# 
# ---------------------------------------------------------------------------
# Optional: Email (for contact forms, notifications)
# ---------------------------------------------------------------------------
# SMTP_HOST=""
# SMTP_PORT=""
# SMTP_USER=""
# SMTP_PASS=""
# FROM_EMAIL="noreply@bajajalprince.com"

# ---------------------------------------------------------------------------
# Optional: Cloud Storage (for product images, documents)
# ---------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_S3_BUCKET=""
# AWS_REGION=""

# =============================================================================
# SECURITY REMINDER
# =============================================================================
# 1. Never commit this file as .env
# 2. Rotate secrets quarterly
# 3. Use different secrets per environment (dev / staging / prod)
# 4. Store production secrets in a vault (GitHub Secrets, AWS Secrets Manager, etc.)
# =============================================================================
