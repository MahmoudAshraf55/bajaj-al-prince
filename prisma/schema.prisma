generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactMessage {
  id        String    @id @default(uuid())
  name      String
  phone     String
  email     String
  message   String
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  deletedAt DateTime? @db.Timestamp(6)
  isDeleted Boolean   @default(false)
  tenantId  String
  updatedAt DateTime? @updatedAt @db.Timestamp(6)

  @@unique([id, tenantId])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model Booking {
  id           String        @id @default(uuid())
  name         String
  phone        String
  model        String
  issue        String
  date         String
  time         String
  status       String        @default("pending")
  createdAt    DateTime      @default(now()) @db.Timestamp(6)
  updatedAt    DateTime      @updatedAt @db.Timestamp(6)
  deletedAt    DateTime?     @db.Timestamp(6)
  isDeleted    Boolean       @default(false)
  tenantId     String
  customerId   String?
  plateNumber  String?
  vehicleId    String?
  email        String?
  customer     Customer?     @relation(fields: [customerId], references: [id])
  vehicle      Vehicle?      @relation(fields: [vehicleId], references: [id])
  reminderLogs ReminderLog[]
  workOrders   WorkOrder[]

  @@unique([tenantId, date, time], name: "Booking_tenantId_date_time_unique", map: "Booking_tenantId_date_time_unique")
  @@unique([id, tenantId])
  @@unique([date, time])
  @@index([tenantId, date, status])
  @@index([tenantId, status, createdAt])
  @@index([date, status])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model Product {
  id                   String                @id @default(uuid())
  name                 String
  description          String?
  price                Decimal               @db.Decimal(10, 2)
  stock                Int                   @default(0)
  category             String
  image                String?
  available            Boolean               @default(true)
  createdAt            DateTime              @default(now()) @db.Timestamp(6)
  updatedAt            DateTime              @updatedAt @db.Timestamp(6)
  deletedAt            DateTime?             @db.Timestamp(6)
  isDeleted            Boolean               @default(false)
  tenantId             String
  activeFrom           DateTime?             @db.Timestamp(6)
  barcode              String?               @unique
  costPrice            Decimal?              @db.Decimal(10, 2)
  expiryDate           DateTime?             @db.Timestamp(6)
  lowStockThreshold    Int                   @default(5)
  nameAr               String?
  sku                  String?
  taxExempt            Boolean               @default(false)
  unit                 String                @default("piece")
  vehicleModel         String?
  taxRate              Decimal?              @db.Decimal(3, 1)
  barcodeScanLogs      BarcodeScanLog[]
  inventoryCountItems  InventoryCountItem[]
  invoiceItems         InvoiceItem[]
  purchaseOrderItems   PurchaseOrderItem[]
  purchaseReceiptItems PurchaseReceiptItem[]
  stockMovements       StockMovement[]
  workOrderParts       WorkOrderPart[]

  @@unique([tenantId, barcode])
  @@unique([id, tenantId])
  @@index([barcode])
  @@index([sku])
  @@index([category])
  @@index([available])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId, category, available])
  @@index([tenantId])
}

model Invoice {
  id              String           @id @default(uuid())
  number          String           @unique
  type            InvoiceType      @default(sale)
  status          InvoiceStatus    @default(draft)
  subtotal        Decimal          @db.Decimal(10, 2)
  taxTotal        Decimal          @default(0) @db.Decimal(10, 2)
  discount        Decimal          @default(0) @db.Decimal(10, 2)
  total           Decimal          @db.Decimal(10, 2)
  paid            Decimal          @default(0) @db.Decimal(10, 2)
  change          Decimal          @default(0) @db.Decimal(10, 2)
  paymentMethod   String?
  notes           String?
  customerId      String?
  customerName    String?
  createdById     String
  createdAt       DateTime         @default(now()) @db.Timestamp(6)
  updatedAt       DateTime         @updatedAt @db.Timestamp(6)
  isDeleted       Boolean          @default(false)
  deletedAt       DateTime?        @db.Timestamp(6)
  tenantId        String
  barcodeScanLogs BarcodeScanLog[]
  createdBy       User             @relation(fields: [createdById], references: [id])
  customer        Customer?        @relation(fields: [customerId], references: [id])
  items           InvoiceItem[]
  payments        InvoicePayment[]

  @@unique([tenantId, number])
  @@unique([id, tenantId])
  @@index([number])
  @@index([type])
  @@index([status])
  @@index([createdById])
  @@index([customerId])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId, status, createdAt])
  @@index([tenantId])
}

model InvoiceItem {
  id          String    @id @default(uuid())
  invoiceId   String
  productId   String
  barcode     String?
  productName String
  unitPrice   Decimal   @db.Decimal(10, 2)
  costPrice   Decimal   @db.Decimal(10, 2)
  quantity    Int
  total       Decimal   @db.Decimal(10, 2)
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @db.Timestamp(6)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime? @db.Timestamp(6)
  tenantId    String
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id])

  @@unique([invoiceId, productId])
  @@unique([id, tenantId])
  @@index([invoiceId])
  @@index([productId])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model InvoicePayment {
  id        String    @id @default(uuid())
  invoiceId String
  method    String
  amount    Decimal   @db.Decimal(10, 2)
  reference String?
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @db.Timestamp(6)
  isDeleted Boolean   @default(false)
  deletedAt DateTime? @db.Timestamp(6)
  tenantId  String?
  invoice   Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([invoiceId])
  @@index([method])
  @@index([isDeleted])
  @@index([tenantId])
}

model StockMovement {
  id          String       @id @default(uuid())
  productId   String
  type        MovementType
  quantity    Int
  reference   String?
  notes       String?
  createdById String
  createdAt   DateTime     @default(now()) @db.Timestamp(6)
  updatedAt   DateTime     @updatedAt @db.Timestamp(6)
  isDeleted   Boolean      @default(false)
  deletedAt   DateTime?    @db.Timestamp(6)
  tenantId    String
  createdBy   User         @relation(fields: [createdById], references: [id])
  product     Product      @relation(fields: [productId], references: [id])

  @@unique([id, tenantId])
  @@index([productId])
  @@index([type])
  @@index([createdById])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model BarcodeScanLog {
  id         String     @id @default(uuid())
  barcode    String
  source     ScanSource
  userId     String?
  invoiceId  String?
  productId  String?
  deviceName String?
  ipAddress  String?
  status     ScanStatus
  createdAt  DateTime   @default(now()) @db.Timestamp(6)
  updatedAt  DateTime   @updatedAt @db.Timestamp(6)
  isDeleted  Boolean    @default(false)
  deletedAt  DateTime?  @db.Timestamp(6)
  tenantId   String
  invoice    Invoice?   @relation(fields: [invoiceId], references: [id])
  product    Product?   @relation(fields: [productId], references: [id])
  user       User?      @relation(fields: [userId], references: [id])

  @@unique([id, tenantId])
  @@index([barcode])
  @@index([source])
  @@index([userId])
  @@index([invoiceId])
  @@index([productId])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model ScannerSession {
  id          String    @id @default(uuid())
  token       String    @unique
  deviceName  String?
  ipAddress   String?
  pin         String?
  status      String    @default("active")
  createdById String
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @db.Timestamp(6)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime? @db.Timestamp(6)
  tenantId    String
  createdBy   User      @relation(fields: [createdById], references: [id])

  @@unique([tenantId, token])
  @@unique([id, tenantId])
  @@index([token])
  @@index([status])
  @@index([createdById])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model AppSetting {
  id        String    @id @default(uuid())
  key       String    @unique
  value     String
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime  @updatedAt @db.Timestamp(6)
  tenantId  String
  isDeleted Boolean   @default(false)
  deletedAt DateTime? @db.Timestamp(6)

  @@unique([tenantId, key])
  @@unique([id, tenantId])
  @@index([key])
  @@index([tenantId])
}

model Transaction {
  id          String    @id @default(uuid())
  type        String
  amount      Decimal   @db.Decimal(10, 2)
  description String?
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  deletedAt   DateTime? @db.Timestamp(6)
  isDeleted   Boolean   @default(false)
  tenantId    String
  updatedAt   DateTime? @updatedAt @db.Timestamp(6)
  createdById String?
  createdBy   User?     @relation(fields: [createdById], references: [id])

  @@unique([id, tenantId])
  @@index([type])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  settings  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  @@index([slug])
  @@index([isActive])
}

model User {
  id                   String             @id @default(uuid())
  username             String             @unique
  password             String
  role                 UserRole           @default(viewer)
  failedAttempts       Int                @default(0)
  lockedUntil          DateTime?          @db.Timestamp(6)
  createdAt            DateTime           @default(now()) @db.Timestamp(6)
  deletedAt            DateTime?          @db.Timestamp(6)
  isDeleted            Boolean            @default(false)
  tenantId             String
  updatedAt            DateTime?          @updatedAt @db.Timestamp(6)
  tokenVersion         Int                @default(0)
  closedPeriods        AccountingPeriod[] @relation("PeriodClosedBy")
  barcodeScanLogs      BarcodeScanLog[]
  countSheetsCompleted InventoryCount[]   @relation("CountCompletedBy")
  countSheetsCreated   InventoryCount[]   @relation("CountCreatedBy")
  invoices             Invoice[]
  journalEntries       JournalEntry[]
  purchaseOrders       PurchaseOrder[]
  purchaseReceipts     PurchaseReceipt[]
  scannerSessions      ScannerSession[]
  stockMovements       StockMovement[]
  transactions         Transaction[]

  @@unique([id, tenantId])
  @@index([username])
  @@index([isDeleted])
  @@index([tenantId])
}

model Customer {
  id           String        @id @default(uuid())
  name         String
  phone        String?
  email        String
  address      String?
  createdAt    DateTime      @default(now()) @db.Timestamp(6)
  updatedAt    DateTime      @updatedAt @db.Timestamp(6)
  isDeleted    Boolean       @default(false)
  deletedAt    DateTime?     @db.Timestamp(6)
  tenantId     String
  bookings     Booking[]
  invoices     Invoice[]
  reminderLogs ReminderLog[]
  vehicles     Vehicle[]

  @@unique([id, tenantId])
  @@index([email])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId, phone, isDeleted])
  @@index([tenantId])
}

model Vehicle {
  id            String      @id @default(uuid())
  make          String
  model         String
  year          Int?
  chassisNumber String?
  plateNumber   String?
  customerId    String
  createdAt     DateTime    @default(now()) @db.Timestamp(6)
  updatedAt     DateTime?   @updatedAt @db.Timestamp(6)
  isDeleted     Boolean     @default(false)
  deletedAt     DateTime?   @db.Timestamp(6)
  tenantId      String
  bookings      Booking[]
  customer      Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workOrders    WorkOrder[]

  @@unique([chassisNumber, tenantId])
  @@unique([id, tenantId])
  @@index([make])
  @@index([model])
  @@index([customerId])
  @@index([isDeleted])
  @@index([tenantId])
}

model Manufacturer {
  id        String         @id @default(uuid())
  name      String
  nameAr    String?
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now()) @db.Timestamp(6)
  updatedAt DateTime?      @updatedAt @db.Timestamp(6)
  isDeleted Boolean        @default(false)
  deletedAt DateTime?      @db.Timestamp(6)
  tenantId  String?
  models    VehicleModel[]

  @@unique([tenantId, name])
  @@unique([id, tenantId])
  @@index([isActive])
  @@index([isDeleted])
  @@index([tenantId])
}

model VehicleModel {
  id             String        @id @default(uuid())
  name           String        @unique
  make           String        @default("Bajaj")
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now()) @db.Timestamp(6)
  updatedAt      DateTime?     @updatedAt @db.Timestamp(6)
  isDeleted      Boolean       @default(false)
  deletedAt      DateTime?     @db.Timestamp(6)
  tenantId       String
  manufacturerId String?
  manufacturer   Manufacturer? @relation(fields: [manufacturerId], references: [id])

  @@unique([tenantId, name])
  @@unique([id, tenantId])
  @@index([isActive])
  @@index([isDeleted])
  @@index([manufacturerId])
  @@index([tenantId])
}

model WorkOrder {
  id          String            @id @default(uuid())
  description String
  status      String            @default("pending")
  cost        Decimal?          @db.Decimal(10, 2)
  vehicleId   String
  createdAt   DateTime          @default(now()) @db.Timestamp(6)
  updatedAt   DateTime?         @updatedAt @db.Timestamp(6)
  isDeleted   Boolean           @default(false)
  deletedAt   DateTime?         @db.Timestamp(6)
  tenantId    String
  bookingId   String?
  booking     Booking?          @relation(fields: [bookingId], references: [id])
  vehicle     Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  labourLines WorkOrderLabour[]
  parts       WorkOrderPart[]

  @@unique([id, tenantId])
  @@index([status])
  @@index([vehicleId])
  @@index([bookingId])
  @@index([tenantId, status, createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model WorkOrderPart {
  id          String    @id @default(dbgenerated("gen_random_uuid()"))
  workOrderId String
  productId   String
  quantity    Int
  unitPrice   Decimal   @db.Decimal(10, 2)
  total       Decimal   @db.Decimal(10, 2)
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime? @updatedAt @db.Timestamp(6)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime? @db.Timestamp(6)
  tenantId    String?
  product     Product   @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([workOrderId])
  @@index([productId])
  @@index([isDeleted])
  @@index([tenantId])
}

model WorkOrderLabour {
  id          String    @id @default(dbgenerated("gen_random_uuid()"))
  workOrderId String
  description String
  hours       Decimal?  @db.Decimal(5, 2)
  rate        Decimal?  @db.Decimal(10, 2)
  total       Decimal   @db.Decimal(10, 2)
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime? @updatedAt @db.Timestamp(6)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime? @db.Timestamp(6)
  tenantId    String?
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([workOrderId])
  @@index([isDeleted])
  @@index([tenantId])
}

model AuditLog {
  id        String    @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValue  String?
  newValue  String?
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  tenantId  String
  isDeleted Boolean   @default(false)
  deletedAt DateTime? @db.Timestamp(6)

  @@unique([id, tenantId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@index([userId])
  @@index([tenantId])
}

model FeatureFlag {
  id              String              @id @default(uuid())
  key             String              @unique
  name            String
  description     String?
  category        String              @default("general")
  defaultEnabled  Boolean             @default(false)
  createdAt       DateTime            @default(now()) @db.Timestamp(6)
  updatedAt       DateTime            @updatedAt @db.Timestamp(6)
  isDeleted       Boolean             @default(false)
  deletedAt       DateTime?           @db.Timestamp(6)
  tenantId        String
  tenantOverrides TenantFeatureFlag[]

  @@unique([tenantId, key])
  @@unique([id, tenantId])
  @@index([key])
  @@index([category])
  @@index([isDeleted])
  @@index([tenantId])
  @@index([tenantId, key])
}

model TenantFeatureFlag {
  id        String      @id @default(uuid())
  tenantId  String
  featureId String
  enabled   Boolean     @default(false)
  createdAt DateTime    @default(now()) @db.Timestamp(6)
  updatedAt DateTime    @updatedAt @db.Timestamp(6)
  isDeleted Boolean     @default(false)
  deletedAt DateTime?   @db.Timestamp(6)
  feature   FeatureFlag @relation(fields: [featureId], references: [id])

  @@unique([tenantId, featureId])
  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([featureId])
  @@index([isDeleted])
}

model Permission {
  id              String           @id @default(uuid())
  key             String           @unique
  name            String
  description     String?
  category        String           @default("general")
  createdAt       DateTime         @default(now()) @db.Timestamp(6)
  updatedAt       DateTime         @updatedAt @db.Timestamp(6)
  isDeleted       Boolean          @default(false)
  deletedAt       DateTime?        @db.Timestamp(6)
  tenantId        String
  rolePermissions RolePermission[]

  @@unique([tenantId, key])
  @@unique([id, tenantId])
  @@index([key])
  @@index([category])
  @@index([isDeleted])
  @@index([tenantId])
  @@index([tenantId, key])
}

model RolePermission {
  id           String     @id @default(uuid())
  role         UserRole
  permissionId String
  createdAt    DateTime   @default(now()) @db.Timestamp(6)
  updatedAt    DateTime   @updatedAt @db.Timestamp(6)
  isDeleted    Boolean    @default(false)
  deletedAt    DateTime?  @db.Timestamp(6)
  tenantId     String
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([role, permissionId])
  @@unique([id, tenantId])
  @@index([role])
  @@index([permissionId])
  @@index([isDeleted])
  @@index([tenantId])
}

model JournalEntry {
  id              String             @id @default(uuid())
  type            JournalEntryType
  amount          Decimal            @db.Decimal(12, 2)
  description     String?
  referenceType   String?
  referenceId     String?
  referenceNumber String?
  category        String?
  paymentMethod   String?
  createdById     String
  date            DateTime           @db.Timestamp(6)
  createdAt       DateTime           @default(now()) @db.Timestamp(6)
  updatedAt       DateTime?          @updatedAt @db.Timestamp(6)
  isDeleted       Boolean            @default(false)
  deletedAt       DateTime?          @db.Timestamp(6)
  tenantId        String
  debitAccountId  String?
  creditAccountId String?
  createdBy       User               @relation(fields: [createdById], references: [id])
  creditAccount   Account?           @relation("CreditEntries", fields: [creditAccountId], references: [id])
  debitAccount    Account?           @relation("DebitEntries", fields: [debitAccountId], references: [id])
  lines           JournalEntryLine[]

  @@unique([id, tenantId])
  @@index([type])
  @@index([date])
  @@index([referenceType, referenceId])
  @@index([createdById])
  @@index([category])
  @@index([debitAccountId])
  @@index([creditAccountId])
  @@index([tenantId, date])
  @@index([isDeleted])
  @@index([tenantId])
}

model JournalEntryLine {
  id             String       @id @default(uuid())
  journalEntryId String
  accountId      String
  debit          Decimal      @default(0) @db.Decimal(12, 2)
  credit         Decimal      @default(0) @db.Decimal(12, 2)
  description    String?
  createdAt      DateTime     @default(now()) @db.Timestamp(6)
  updatedAt      DateTime?    @updatedAt @db.Timestamp(6)
  isDeleted      Boolean      @default(false)
  deletedAt      DateTime?    @db.Timestamp(6)
  tenantId       String?
  account        Account      @relation("JournalEntryLines", fields: [accountId], references: [id])
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([journalEntryId])
  @@index([accountId])
  @@index([isDeleted])
  @@index([tenantId])
}

model Review {
  id        String    @id @default(uuid())
  name      String
  rating    Float
  review    String
  date      String
  avatar    String?
  verified  Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @db.Timestamp(6)
  isDeleted Boolean   @default(false)
  deletedAt DateTime? @db.Timestamp(6)
  tenantId  String

  @@unique([id, tenantId])
  @@index([rating])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model UniqueVisitor {
  id        String    @id @default(uuid())
  ipHash    String    @unique
  userAgent String?
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  isDeleted Boolean   @default(false)
  deletedAt DateTime? @db.Timestamp(6)
  tenantId  String

  @@unique([tenantId, ipHash])
  @@unique([id, tenantId])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model ReminderLog {
  id         String    @id @default(uuid())
  customerId String
  bookingId  String?
  phone      String
  message    String
  status     String    @default("sent")
  sentAt     DateTime  @default(now()) @db.Timestamp(6)
  isDeleted  Boolean   @default(false)
  deletedAt  DateTime? @db.Timestamp(6)
  tenantId   String
  booking    Booking?  @relation(fields: [bookingId], references: [id])
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([customerId])
  @@index([sentAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model WhatsAppSettings {
  id        String   @id @default("default")
  delayMin  Int      @default(60)
  delayMax  Int      @default(120)
  dailyCap  Int      @default(50)
  batchSize Int      @default(20)
  updatedAt DateTime @updatedAt @db.Timestamp(6)
  tenantId  String

  @@unique([tenantId, id])
  @@unique([id, tenantId])
  @@index([tenantId])
}

model WhatsAppMessageTemplate {
  id        String    @id @default(cuid())
  event     String    @unique
  message   String
  isActive  Boolean   @default(true)
  updatedAt DateTime  @updatedAt @db.Timestamp(6)
  tenantId  String
  deletedAt DateTime? @db.Timestamp(6)
  isDeleted Boolean   @default(false)

  @@unique([tenantId, event])
  @@unique([id, tenantId])
  @@index([tenantId])
}

model ReminderSchedule {
  id           String    @id @default(cuid())
  name         String
  intervalDays Int
  message      String
  isActive     Boolean   @default(true)
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime? @db.Timestamp(6)
  createdAt    DateTime  @default(now()) @db.Timestamp(6)
  updatedAt    DateTime  @updatedAt @db.Timestamp(6)
  tenantId     String

  @@unique([id, tenantId])
  @@index([tenantId])
}

model AccountingPeriod {
  id         String       @id @default(uuid())
  name       String
  startDate  DateTime     @db.Date
  endDate    DateTime     @db.Date
  status     PeriodStatus @default(open)
  closedById String?
  closedAt   DateTime?    @db.Timestamp(6)
  notes      String?
  createdAt  DateTime     @default(now()) @db.Timestamp(6)
  updatedAt  DateTime     @updatedAt @db.Timestamp(6)
  isDeleted  Boolean      @default(false)
  deletedAt  DateTime?    @db.Timestamp(6)
  tenantId   String
  closedBy   User?        @relation("PeriodClosedBy", fields: [closedById], references: [id])

  @@unique([startDate, tenantId])
  @@unique([id, tenantId])
  @@index([status])
  @@index([startDate])
  @@index([isDeleted])
  @@index([tenantId])
}

model InventoryCount {
  id            String               @id @default(uuid())
  name          String
  status        CountSheetStatus     @default(draft)
  notes         String?
  createdById   String
  completedById String?
  completedAt   DateTime?            @db.Timestamp(6)
  createdAt     DateTime             @default(now()) @db.Timestamp(6)
  updatedAt     DateTime             @updatedAt @db.Timestamp(6)
  isDeleted     Boolean              @default(false)
  deletedAt     DateTime?            @db.Timestamp(6)
  tenantId      String
  completedBy   User?                @relation("CountCompletedBy", fields: [completedById], references: [id])
  createdBy     User                 @relation("CountCreatedBy", fields: [createdById], references: [id])
  items         InventoryCountItem[]

  @@unique([id, tenantId])
  @@index([status])
  @@index([createdById])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model InventoryCountItem {
  id          String         @id @default(uuid())
  countId     String
  productId   String
  expectedQty Int
  actualQty   Int            @default(0)
  variance    Int            @default(0)
  unit        String         @default("piece")
  notes       String?
  createdAt   DateTime       @default(now()) @db.Timestamp(6)
  updatedAt   DateTime?      @updatedAt @db.Timestamp(6)
  isDeleted   Boolean        @default(false)
  deletedAt   DateTime?      @db.Timestamp(6)
  tenantId    String
  count       InventoryCount @relation(fields: [countId], references: [id], onDelete: Cascade)
  product     Product        @relation(fields: [productId], references: [id])

  @@unique([countId, productId])
  @@unique([id, tenantId])
  @@index([countId])
  @@index([productId])
  @@index([isDeleted])
  @@index([tenantId])
}

model Supplier {
  id             String          @id @default(uuid())
  name           String
  nameAr         String?
  email          String?
  phone          String?
  address        String?
  taxId          String?
  notes          String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now()) @db.Timestamp(6)
  updatedAt      DateTime?       @updatedAt @db.Timestamp(6)
  isDeleted      Boolean         @default(false)
  deletedAt      DateTime?       @db.Timestamp(6)
  tenantId       String?
  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, name])
  @@unique([id, tenantId])
  @@index([tenantId, isActive])
  @@index([isDeleted])
  @@index([tenantId])
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  number      String
  supplierId  String
  status      String              @default("draft")
  notes       String?
  subtotal    Decimal             @db.Decimal(10, 2)
  taxTotal    Decimal             @default(0) @db.Decimal(10, 2)
  discount    Decimal             @default(0) @db.Decimal(10, 2)
  total       Decimal             @db.Decimal(10, 2)
  createdById String
  createdAt   DateTime            @default(now()) @db.Timestamp(6)
  updatedAt   DateTime?           @updatedAt @db.Timestamp(6)
  isDeleted   Boolean             @default(false)
  deletedAt   DateTime?           @db.Timestamp(6)
  tenantId    String?
  createdBy   User                @relation(fields: [createdById], references: [id])
  supplier    Supplier            @relation(fields: [supplierId], references: [id])
  items       PurchaseOrderItem[]
  receipts    PurchaseReceipt[]

  @@unique([tenantId, number])
  @@unique([id, tenantId])
  @@index([tenantId, status])
  @@index([tenantId, supplierId])
  @@index([isDeleted])
  @@index([tenantId])
}

model PurchaseOrderItem {
  id              String                @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  receivedQty     Int                   @default(0)
  unitPrice       Decimal               @db.Decimal(10, 2)
  total           Decimal               @db.Decimal(10, 2)
  createdAt       DateTime              @default(now()) @db.Timestamp(6)
  updatedAt       DateTime?             @updatedAt @db.Timestamp(6)
  isDeleted       Boolean               @default(false)
  deletedAt       DateTime?             @db.Timestamp(6)
  tenantId        String?
  product         Product               @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  receiptItems    PurchaseReceiptItem[]

  @@unique([purchaseOrderId, productId])
  @@unique([id, tenantId])
  @@index([purchaseOrderId])
  @@index([productId])
  @@index([isDeleted])
  @@index([tenantId])
}

model PurchaseReceipt {
  id              String                @id @default(uuid())
  purchaseOrderId String
  receiptNumber   String
  notes           String?
  receivedById    String
  createdAt       DateTime              @default(now()) @db.Timestamp(6)
  updatedAt       DateTime?             @updatedAt @db.Timestamp(6)
  isDeleted       Boolean               @default(false)
  deletedAt       DateTime?             @db.Timestamp(6)
  tenantId        String?
  purchaseOrder   PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id])
  receivedBy      User                  @relation(fields: [receivedById], references: [id])
  items           PurchaseReceiptItem[]

  @@unique([tenantId, receiptNumber])
  @@unique([id, tenantId])
  @@index([tenantId, purchaseOrderId])
  @@index([isDeleted])
  @@index([tenantId])
}

model PurchaseReceiptItem {
  id          String            @id @default(uuid())
  receiptId   String
  orderItemId String
  productId   String
  quantity    Int
  unitPrice   Decimal           @db.Decimal(10, 2)
  total       Decimal           @db.Decimal(10, 2)
  createdAt   DateTime          @default(now()) @db.Timestamp(6)
  updatedAt   DateTime?         @updatedAt @db.Timestamp(6)
  isDeleted   Boolean           @default(false)
  deletedAt   DateTime?         @db.Timestamp(6)
  tenantId    String?
  orderItem   PurchaseOrderItem @relation(fields: [orderItemId], references: [id])
  product     Product           @relation(fields: [productId], references: [id])
  receipt     PurchaseReceipt   @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([receiptId])
  @@index([orderItemId])
  @@index([productId])
  @@index([isDeleted])
  @@index([tenantId])
}

model Account {
  id            String             @id @default(uuid())
  code          String
  name          String
  nameAr        String?
  type          AccountType
  isActive      Boolean            @default(true)
  parentId      String?
  description   String?
  createdAt     DateTime           @default(now()) @db.Timestamp(6)
  updatedAt     DateTime?          @updatedAt @db.Timestamp(6)
  isDeleted     Boolean            @default(false)
  deletedAt     DateTime?          @db.Timestamp(6)
  tenantId      String?
  parent        Account?           @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      Account[]          @relation("AccountHierarchy")
  creditEntries JournalEntry[]     @relation("CreditEntries")
  debitEntries  JournalEntry[]     @relation("DebitEntries")
  journalLines  JournalEntryLine[] @relation("JournalEntryLines")

  @@unique([tenantId, code])
  @@unique([id, tenantId])
  @@index([type])
  @@index([code])
  @@index([parentId])
  @@index([isActive])
  @@index([isDeleted])
  @@index([tenantId])
}

enum InvoiceType {
  sale
  purchase
  return
}

enum InvoiceStatus {
  draft
  confirmed
  cancelled
}

enum MovementType {
  in
  out
  adjustment
}

enum ScanSource {
  HH400
  MobileCamera
  Webcam
}

enum ScanStatus {
  success
  not_found
  error
}

enum UserRole {
  admin
  staff
  viewer
}

enum JournalEntryType {
  SALE
  RETURN
  PURCHASE
  EXPENSE
  INCOME
  STOCK_ADJUSTMENT
}

enum PeriodStatus {
  open
  closed
  locked
}

enum CountSheetStatus {
  draft
  in_progress
  completed
  cancelled
}

enum AccountType {
  asset
  liability
  equity
  revenue
  expense
}
