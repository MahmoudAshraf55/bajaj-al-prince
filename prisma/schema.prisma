generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactMessage {
  id        String    @id @default(uuid())
  name      String
  phone     String
  email     String
  message   String
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @db.Timestamp(6)
  isDeleted Boolean   @default(false)
  deletedAt DateTime? @db.Timestamp(6)
  tenantId  String?

  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model Booking {
  id          String    @id @default(uuid())
  name        String
  email       String?
  phone       String
  model       String
  issue       String
  date        String
  time        String
  status      String    @default("pending")
  plateNumber String?
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  vehicleId   String?
  vehicle     Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @db.Timestamp(6)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime? @db.Timestamp(6)
  tenantId    String?

  @@unique([date, time], name: "Booking_date_time_unique")
  @@index([date, status])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model Product {
  id          String    @id @default(uuid())
  name        String
  description String?
  price       Decimal   @db.Decimal(10, 2)
  stock       Int       @default(0)
  category    String
  image       String?
  available   Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @db.Timestamp(6)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime? @db.Timestamp(6)
  tenantId    String?

  @@index([category])
  @@index([available])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model Transaction {
  id          String    @id @default(uuid())
  type        String
  amount      Decimal   @db.Decimal(10, 2)
  description String?
  createdBy   String?
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime? @updatedAt @db.Timestamp(6)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime? @db.Timestamp(6)
  tenantId    String?

  @@index([type])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

enum UserRole {
  admin
  staff
  viewer
}

model User {
  id             String    @id @default(uuid())
  username       String    @unique
  password       String
  role           UserRole  @default(viewer)
  failedAttempts Int       @default(0)
  lockedUntil    DateTime? @db.Timestamp(6)
  tokenVersion   Int       @default(0)
  createdAt      DateTime  @default(now()) @db.Timestamp(6)
  updatedAt      DateTime? @updatedAt @db.Timestamp(6)
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime? @db.Timestamp(6)
  tenantId       String?

  @@index([username])
  @@index([isDeleted])
  @@index([tenantId])
}

model Customer {
  id        String    @id @default(uuid())
  name      String
  phone     String
  email     String?
  address   String?
  vehicles  Vehicle[]
  bookings  Booking[]
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @db.Timestamp(6)
  isDeleted Boolean   @default(false)
  deletedAt DateTime? @db.Timestamp(6)
  tenantId  String?

  @@index([name])
  @@index([phone])
  @@index([isDeleted])
  @@index([tenantId])
}

model Vehicle {
  id            String      @id @default(uuid())
  make          String
  model         String
  year          Int?
  chassisNumber String?
  plateNumber   String?
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  bookings      Booking[]
  workOrders    WorkOrder[]
  createdAt     DateTime    @default(now()) @db.Timestamp(6)
  updatedAt     DateTime?   @updatedAt @db.Timestamp(6)
  isDeleted     Boolean     @default(false)
  deletedAt     DateTime?   @db.Timestamp(6)
  tenantId      String?

  @@unique([chassisNumber, tenantId])
  @@index([make])
  @@index([model])
  @@index([customerId])
  @@index([isDeleted])
  @@index([tenantId])
}

model VehicleModel {
  id        String    @id @default(uuid())
  name      String    @unique
  make      String    @default("Bajaj")
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @db.Timestamp(6)
  isDeleted Boolean   @default(false)
  deletedAt DateTime? @db.Timestamp(6)
  tenantId  String?

  @@index([isActive])
  @@index([isDeleted])
  @@index([tenantId])
}

model WorkOrder {
  id          String    @id @default(uuid())
  description String
  status      String    @default("pending")
  cost        Decimal?  @db.Decimal(10, 2)
  vehicleId   String
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime? @updatedAt @db.Timestamp(6)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime? @db.Timestamp(6)
  tenantId    String?

  @@index([status])
  @@index([vehicleId])
  @@index([isDeleted])
  @@index([tenantId])
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String
  entity      String
  entityId    String?
  oldValue    String?
  newValue    String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  tenantId    String?

  @@index([entity, entityId])
  @@index([createdAt])
  @@index([userId])
  @@index([tenantId])
}

model Review {
  id        String    @id @default(uuid())
  name      String
  rating    Float
  review    String
  date      String
  avatar    String?
  verified  Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @db.Timestamp(6)
  isDeleted Boolean   @default(false)
  deletedAt DateTime? @db.Timestamp(6)
  tenantId  String?

  @@index([rating])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model UniqueVisitor {
  id        String    @id @default(uuid())
  ipHash    String    @unique
  userAgent String?
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  isDeleted Boolean   @default(false)
  deletedAt DateTime? @db.Timestamp(6)
  tenantId  String?

  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model ReminderLog {
  id         String   @id @default(uuid())
  customerId String
  bookingId  String?
  phone      String
  message    String
  status     String   @default("sent")
  sentAt     DateTime @default(now()) @db.Timestamp(6)
  isDeleted  Boolean  @default(false)
  deletedAt  DateTime? @db.Timestamp(6)
  tenantId   String?

  @@index([customerId])
  @@index([sentAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model WhatsAppSettings {
  id         String   @id @default("default")
  delayMin   Int      @default(60)
  delayMax   Int      @default(120)
  dailyCap   Int      @default(50)
  batchSize  Int      @default(20)
  updatedAt  DateTime @updatedAt @db.Timestamp(6)
  tenantId   String?

  @@index([tenantId])
}

model WhatsAppMessageTemplate {
  id        String    @id @default(cuid())
  event     String    @unique // e.g. booking_created, booking_accepted, booking_rejected, booking_completed, issue_changed, vehicle_added
  message   String
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime? @db.Timestamp(6)
  updatedAt DateTime  @updatedAt @db.Timestamp(6)
  tenantId  String?

  @@index([tenantId])
}
