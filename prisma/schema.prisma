generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactMessage {
  id        String    @id @default(uuid())
  name      String
  phone     String
  email     String
  message   String
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @db.Timestamp(6)
  isDeleted Boolean   @default(false)
  deletedAt DateTime? @db.Timestamp(6)
  tenantId  String?

  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model Booking {
  id          String    @id @default(uuid())
  name        String
  phone       String
  model       String
  issue       String
  date        String
  time        String
  status      String    @default("pending")
  plateNumber String?
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  vehicleId   String?
  vehicle     Vehicle?  @relation(fields: [vehicleId], references: [id])
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @db.Timestamp(6)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime? @db.Timestamp(6)
  tenantId    String?

  @@unique([date, time], name: "Booking_date_time_unique")
  @@index([date, status])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model Product {
  id          String    @id @default(uuid())
  name        String
  description String?
  price       Decimal   @db.Decimal(10, 2)
  stock       Int       @default(0)
  category    String
  image       String?
  available   Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @db.Timestamp(6)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime? @db.Timestamp(6)
  tenantId    String?

  @@index([category])
  @@index([available])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model Transaction {
  id          String    @id @default(uuid())
  type        String
  amount      Decimal   @db.Decimal(10, 2)
  description String?
  createdBy   String?
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime? @updatedAt @db.Timestamp(6)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime? @db.Timestamp(6)
  tenantId    String?

  @@index([type])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

enum UserRole {
  admin
  staff
  viewer
}

model User {
  id             String    @id @default(uuid())
  username       String    @unique
  password       String
  role           UserRole  @default(viewer)
  failedAttempts Int       @default(0)
  lockedUntil    DateTime? @db.Timestamp(6)
  createdAt      DateTime  @default(now()) @db.Timestamp(6)
  updatedAt      DateTime? @updatedAt @db.Timestamp(6)
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime? @db.Timestamp(6)
  tenantId       String?

  @@index([username])
  @@index([isDeleted])
  @@index([tenantId])
}

model Customer {
  id        String    @id @default(uuid())
  name      String
  phone     String
  email     String?
  address   String?
  vehicles  Vehicle[]
  bookings  Booking[]
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @db.Timestamp(6)
  isDeleted Boolean   @default(false)
  deletedAt DateTime? @db.Timestamp(6)
  tenantId  String?

  @@index([name])
  @@index([phone])
  @@index([isDeleted])
  @@index([tenantId])
}

model Vehicle {
  id            String      @id @default(uuid())
  make          String
  model         String
  year          Int?
  chassisNumber String?
  plateNumber   String?
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id])
  bookings      Booking[]
  workOrders    WorkOrder[]
  createdAt     DateTime    @default(now()) @db.Timestamp(6)
  updatedAt     DateTime?   @updatedAt @db.Timestamp(6)
  isDeleted     Boolean     @default(false)
  deletedAt     DateTime?   @db.Timestamp(6)
  tenantId      String?

  @@unique([chassisNumber, tenantId])
  @@index([make])
  @@index([model])
  @@index([customerId])
  @@index([isDeleted])
  @@index([tenantId])
}

model VehicleModel {
  id        String    @id @default(uuid())
  name      String    @unique
  make      String    @default("Bajaj")
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @db.Timestamp(6)
  isDeleted Boolean   @default(false)
  deletedAt DateTime? @db.Timestamp(6)
  tenantId  String?

  @@index([isActive])
  @@index([isDeleted])
  @@index([tenantId])
}

model WorkOrder {
  id          String    @id @default(uuid())
  description String
  status      String    @default("pending")
  cost        Decimal?  @db.Decimal(10, 2)
  vehicleId   String
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime? @updatedAt @db.Timestamp(6)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime? @db.Timestamp(6)
  tenantId    String?

  @@index([status])
  @@index([vehicleId])
  @@index([isDeleted])
  @@index([tenantId])
}
