generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactMessage {
  id        String    @id @default(uuid())
  name      String
  phone     String
  email     String
  message   String
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @db.Timestamp(6)
  isDeleted Boolean   @default(false)
  deletedAt DateTime? @db.Timestamp(6)
  tenantId  String?

  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model Booking {
  id          String      @id @default(uuid())
  name        String
  email       String?
  phone       String
  model       String
  issue       String
  date        String
  time        String
  status      String      @default("pending")
  plateNumber String?
  customerId  String?
  customer    Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  vehicleId   String?
  vehicle     Vehicle?    @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  workOrders  WorkOrder[]
  createdAt   DateTime    @default(now()) @db.Timestamp(6)
  updatedAt   DateTime    @updatedAt @db.Timestamp(6)
  isDeleted   Boolean     @default(false)
  deletedAt   DateTime?   @db.Timestamp(6)
  tenantId    String?

  @@unique([date, time], name: "Booking_date_time_unique")
  @@index([date, status])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model Product {
  id                String          @id @default(uuid())
  name              String
  nameAr            String?
  description       String?
  barcode           String?         @unique
  sku               String?
  price             Decimal         @db.Decimal(10, 2)
  costPrice         Decimal?        @db.Decimal(10, 2)
  stock             Int             @default(0)
  lowStockThreshold Int             @default(5)
  unit              String          @default("piece")
  category          String
  vehicleModel      String?
  image             String?
  available         Boolean         @default(true)
  taxExempt         Boolean         @default(false)
  taxRate           Decimal?        @db.Decimal(3, 1)
  activeFrom        DateTime?       @db.Timestamp(6)
  expiryDate        DateTime?       @db.Timestamp(6)
  invoiceItems      InvoiceItem[]
  stockMovements    StockMovement[]
  barcodeScanLogs   BarcodeScanLog[]
  inventoryCountItems InventoryCountItem[]
  createdAt         DateTime        @default(now()) @db.Timestamp(6)
  updatedAt         DateTime        @updatedAt @db.Timestamp(6)
  isDeleted         Boolean         @default(false)
  deletedAt         DateTime?       @db.Timestamp(6)
  tenantId          String?

  @@index([barcode])
  @@index([sku])
  @@index([category])
  @@index([available])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

enum InvoiceType {
  sale
  purchase
  return
}

enum InvoiceStatus {
  draft
  confirmed
  cancelled
}

model Invoice {
  id            String        @id @default(uuid())
  number        String        @unique
  type          InvoiceType   @default(sale)
  status        InvoiceStatus @default(draft)
  subtotal      Decimal       @db.Decimal(10, 2)
  taxTotal      Decimal       @db.Decimal(10, 2) @default(0)
  discount      Decimal       @db.Decimal(10, 2) @default(0)
  total         Decimal       @db.Decimal(10, 2)
  paid          Decimal       @db.Decimal(10, 2) @default(0)
  change        Decimal       @db.Decimal(10, 2) @default(0)
  paymentMethod String?
  notes         String?
  customerId    String?
  customer      Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName  String?
  createdById   String
  createdBy     User          @relation(fields: [createdById], references: [id])
  items         InvoiceItem[]
  barcodeScanLogs BarcodeScanLog[]
  createdAt     DateTime      @default(now()) @db.Timestamp(6)
  updatedAt     DateTime      @updatedAt @db.Timestamp(6)
  isDeleted     Boolean       @default(false)
  deletedAt     DateTime?     @db.Timestamp(6)
  tenantId      String?

  @@index([number])
  @@index([type])
  @@index([status])
  @@index([createdById])
  @@index([customerId])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model InvoiceItem {
  id          String    @id @default(uuid())
  invoiceId   String
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  barcode     String?
  productName String
  unitPrice   Decimal   @db.Decimal(10, 2)
  costPrice   Decimal   @db.Decimal(10, 2)
  quantity    Int
  total       Decimal   @db.Decimal(10, 2)
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @db.Timestamp(6)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime? @db.Timestamp(6)
  tenantId    String?

  @@index([invoiceId])
  @@index([productId])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

enum MovementType {
  in
  out
  adjustment
}

model StockMovement {
  id          String       @id @default(uuid())
  productId   String
  product     Product      @relation(fields: [productId], references: [id])
  type        MovementType
  quantity    Int
  reference   String?
  notes       String?
  createdById String
  createdBy   User         @relation(fields: [createdById], references: [id])
  createdAt   DateTime     @default(now()) @db.Timestamp(6)
  updatedAt   DateTime     @updatedAt @db.Timestamp(6)
  isDeleted   Boolean      @default(false)
  deletedAt   DateTime?    @db.Timestamp(6)
  tenantId    String?

  @@index([productId])
  @@index([type])
  @@index([createdById])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

enum ScanSource {
  HH400
  MobileCamera
  Webcam
}

enum ScanStatus {
  success
  not_found
  error
}

model BarcodeScanLog {
  id         String     @id @default(uuid())
  barcode    String
  source     ScanSource
  userId     String?
  user       User?      @relation(fields: [userId], references: [id])
  invoiceId  String?
  invoice    Invoice?   @relation(fields: [invoiceId], references: [id])
  productId  String?
  product    Product?   @relation(fields: [productId], references: [id])
  deviceName String?
  ipAddress  String?
  status     ScanStatus
  createdAt  DateTime   @default(now()) @db.Timestamp(6)
  updatedAt  DateTime   @updatedAt @db.Timestamp(6)
  isDeleted  Boolean    @default(false)
  deletedAt  DateTime?  @db.Timestamp(6)
  tenantId   String?

  @@index([barcode])
  @@index([source])
  @@index([userId])
  @@index([invoiceId])
  @@index([productId])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model ScannerSession {
  id         String   @id @default(uuid())
  token      String   @unique
  deviceName String?
  ipAddress  String?
  pin        String?
  status     String   @default("active") // active | disconnected
  createdById String
  createdBy  User     @relation(fields: [createdById], references: [id])
  createdAt  DateTime @default(now()) @db.Timestamp(6)
  updatedAt  DateTime @updatedAt @db.Timestamp(6)
  isDeleted  Boolean  @default(false)
  deletedAt  DateTime? @db.Timestamp(6)
  tenantId   String?

  @@index([token])
  @@index([status])
  @@index([createdById])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)
  tenantId  String?

  @@index([key])
  @@index([tenantId])
}

model Transaction {
  id          String    @id @default(uuid())
  type        String
  amount      Decimal   @db.Decimal(10, 2)
  description String?
  createdBy   String?
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime? @updatedAt @db.Timestamp(6)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime? @db.Timestamp(6)
  tenantId    String?

  @@index([type])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

enum UserRole {
  admin
  staff
  viewer
}

model User {
  id                String             @id @default(uuid())
  username          String             @unique
  password          String
  role              UserRole           @default(viewer)
  failedAttempts    Int                @default(0)
  lockedUntil       DateTime?          @db.Timestamp(6)
  tokenVersion      Int                @default(0)
  invoices          Invoice[]
  stockMovements    StockMovement[]
  journalEntries    JournalEntry[]
  barcodeScanLogs   BarcodeScanLog[]
  scannerSessions   ScannerSession[]
  closedPeriods     AccountingPeriod[] @relation("PeriodClosedBy")
  countSheetsCreated InventoryCount[] @relation("CountCreatedBy")
  countSheetsCompleted InventoryCount[] @relation("CountCompletedBy")
  createdAt         DateTime           @default(now()) @db.Timestamp(6)
  updatedAt         DateTime?          @updatedAt @db.Timestamp(6)
  isDeleted         Boolean            @default(false)
  deletedAt         DateTime?          @db.Timestamp(6)
  tenantId          String?

  @@index([username])
  @@index([isDeleted])
  @@index([tenantId])
}

model Customer {
  id        String      @id @default(uuid())
  name      String
  email     String
  phone     String?
  address   String?
  vehicles  Vehicle[]
  bookings  Booking[]
  invoices  Invoice[]
  createdAt DateTime   @default(now()) @db.Timestamp(6)
  updatedAt DateTime   @updatedAt @db.Timestamp(6)
  isDeleted Boolean    @default(false)
  deletedAt DateTime?  @db.Timestamp(6)
  tenantId  String?

  @@index([email])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model Vehicle {
  id            String      @id @default(uuid())
  make          String
  model         String
  year          Int?
  chassisNumber String?
  plateNumber   String?
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  bookings      Booking[]
  workOrders    WorkOrder[]
  createdAt     DateTime    @default(now()) @db.Timestamp(6)
  updatedAt     DateTime?   @updatedAt @db.Timestamp(6)
  isDeleted     Boolean     @default(false)
  deletedAt     DateTime?   @db.Timestamp(6)
  tenantId      String?

  @@unique([chassisNumber, tenantId])
  @@index([make])
  @@index([model])
  @@index([customerId])
  @@index([isDeleted])
  @@index([tenantId])
}

model VehicleModel {
  id        String    @id @default(uuid())
  name      String    @unique
  make      String    @default("Bajaj")
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @db.Timestamp(6)
  isDeleted Boolean   @default(false)
  deletedAt DateTime? @db.Timestamp(6)
  tenantId  String?

  @@index([isActive])
  @@index([isDeleted])
  @@index([tenantId])
}

model WorkOrder {
  id          String    @id @default(uuid())
  description String
  status      String    @default("pending")
  cost        Decimal?  @db.Decimal(10, 2)
  vehicleId   String
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  bookingId   String?
  booking     Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime? @updatedAt @db.Timestamp(6)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime? @db.Timestamp(6)
  tenantId    String?

  @@index([status])
  @@index([vehicleId])
  @@index([bookingId])
  @@index([isDeleted])
  @@index([tenantId])
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String
  entity      String
  entityId    String?
  oldValue    String?
  newValue    String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  tenantId    String?

  @@index([entity, entityId])
  @@index([createdAt])
  @@index([userId])
  @@index([tenantId])
}

enum JournalEntryType {
  SALE
  RETURN
  PURCHASE
  EXPENSE
  INCOME
  STOCK_ADJUSTMENT
}

model JournalEntry {
  id              String           @id @default(uuid())
  type            JournalEntryType
  amount          Decimal          @db.Decimal(12, 2)
  description     String?
  referenceType   String?          // "invoice" | "stock_movement" | "manual_transaction" | "work_order"
  referenceId     String?          // ID of the source document
  referenceNumber String?          // Human-readable ref (e.g., INV-20260627-0001)
  category        String?          // Product category or expense category
  paymentMethod   String?          // "cash" | "card" | "transfer"
  createdById     String
  createdBy       User             @relation(fields: [createdById], references: [id])
  date            DateTime         @db.Timestamp(6)
  createdAt       DateTime         @default(now()) @db.Timestamp(6)
  updatedAt       DateTime?        @updatedAt @db.Timestamp(6)
  isDeleted       Boolean          @default(false)
  deletedAt       DateTime?        @db.Timestamp(6)
  tenantId        String?

  @@index([type])
  @@index([date])
  @@index([referenceType, referenceId])
  @@index([createdById])
  @@index([category])
  @@index([isDeleted])
  @@index([tenantId])
}

model Review {
  id        String    @id @default(uuid())
  name      String
  rating    Float
  review    String
  date      String
  avatar    String?
  verified  Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @db.Timestamp(6)
  isDeleted Boolean   @default(false)
  deletedAt DateTime? @db.Timestamp(6)
  tenantId  String?

  @@index([rating])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model UniqueVisitor {
  id        String    @id @default(uuid())
  ipHash    String    @unique
  userAgent String?
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  isDeleted Boolean   @default(false)
  deletedAt DateTime? @db.Timestamp(6)
  tenantId  String?

  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model ReminderLog {
  id         String   @id @default(uuid())
  customerId String
  bookingId  String?
  phone      String
  message    String
  status     String   @default("sent")
  sentAt     DateTime @default(now()) @db.Timestamp(6)
  isDeleted  Boolean  @default(false)
  deletedAt  DateTime? @db.Timestamp(6)
  tenantId   String?

  @@index([customerId])
  @@index([sentAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model WhatsAppSettings {
  id         String   @id @default("default")
  delayMin   Int      @default(60)
  delayMax   Int      @default(120)
  dailyCap   Int      @default(50)
  batchSize  Int      @default(20)
  updatedAt  DateTime @updatedAt @db.Timestamp(6)
  tenantId   String?

  @@index([tenantId])
}

model WhatsAppMessageTemplate {
  id        String    @id @default(cuid())
  event     String    @unique // e.g. booking_created, booking_accepted, booking_rejected, booking_completed, issue_changed, vehicle_added
  message   String
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime? @db.Timestamp(6)
  updatedAt DateTime  @updatedAt @db.Timestamp(6)
  tenantId  String?

  @@index([tenantId])
}

model ReminderSchedule {
  id           String    @id @default(cuid())
  name         String    // e.g. "صيانة دورية", "متابعة", "عرض خاص"
  intervalDays Int       // days since last completed booking; 0 = manual/broadcast
  message      String    // reminder message template
  isActive     Boolean   @default(true)
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime? @db.Timestamp(6)
  createdAt    DateTime  @default(now()) @db.Timestamp(6)
  updatedAt    DateTime  @updatedAt @db.Timestamp(6)
  tenantId     String?

  @@index([tenantId])
}

enum PeriodStatus {
  open
  closed
  locked
}

model AccountingPeriod {
  id         String       @id @default(uuid())
  name       String       // e.g. "January 2026"
  startDate  DateTime     @db.Date
  endDate    DateTime     @db.Date
  status     PeriodStatus @default(open)
  closedById String?
  closedBy   User?        @relation("PeriodClosedBy", fields: [closedById], references: [id])
  closedAt   DateTime?    @db.Timestamp(6)
  notes      String?
  createdAt  DateTime     @default(now()) @db.Timestamp(6)
  updatedAt  DateTime     @updatedAt @db.Timestamp(6)
  isDeleted  Boolean      @default(false)
  deletedAt  DateTime?    @db.Timestamp(6)
  tenantId   String?

  @@unique([startDate, tenantId])
  @@index([status])
  @@index([startDate])
  @@index([isDeleted])
  @@index([tenantId])
}

enum CountSheetStatus {
  draft
  in_progress
  completed
  cancelled
}

model InventoryCount {
  id         String             @id @default(uuid())
  name       String             // e.g. "Monthly Count - June 2026"
  status     CountSheetStatus   @default(draft)
  items      InventoryCountItem[]
  notes      String?
  createdById String
  createdBy  User               @relation("CountCreatedBy", fields: [createdById], references: [id])
  completedById String?
  completedBy User?             @relation("CountCompletedBy", fields: [completedById], references: [id])
  completedAt DateTime?         @db.Timestamp(6)
  createdAt  DateTime           @default(now()) @db.Timestamp(6)
  updatedAt  DateTime           @updatedAt @db.Timestamp(6)
  isDeleted  Boolean            @default(false)
  deletedAt  DateTime?          @db.Timestamp(6)
  tenantId   String?

  @@index([status])
  @@index([createdById])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([tenantId])
}

model InventoryCountItem {
  id             String          @id @default(uuid())
  countId        String
  count          InventoryCount  @relation(fields: [countId], references: [id], onDelete: Cascade)
  productId      String
  product        Product         @relation(fields: [productId], references: [id])
  expectedQty    Int
  actualQty      Int             @default(0)
  variance       Int             @default(0)
  unit           String          @default("piece")
  notes          String?
  createdAt      DateTime        @default(now()) @db.Timestamp(6)
  updatedAt      DateTime?       @updatedAt @db.Timestamp(6)
  isDeleted      Boolean         @default(false)
  deletedAt      DateTime?       @db.Timestamp(6)
  tenantId       String?

  @@unique([countId, productId])
  @@index([countId])
  @@index([productId])
  @@index([isDeleted])
  @@index([tenantId])
}
